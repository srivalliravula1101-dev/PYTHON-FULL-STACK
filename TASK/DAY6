<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Calculator</title>
    <style>
      * {
        margin: 0px;
        padding: 0px;
        font-family: Arial, Helvetica, sans-serif;
      }
      body {
        height: 100vh;
        display: flex;
        justify-content: center;
        align-items: center;
        background: azure;
      }
      .calculator {
        width: 350px;
        background: black;
        padding: 20px;
        border-radius: 20px;
        box-shadow: 0 10px 20px rgba(0, 0, 0, 0.3);
      }
      .calculator input {
        width: 100%;
        height: 80px;
        background: rgb(230, 216, 216);
        color: white;
        font-size: 35px;
        text-align: right;
        border-radius: 10px;
      }
      .buttons {
        display: grid;
        grid-template-columns: repeat(4, 1fr);
        gap: 15px;
        padding-top: 20px;
      }
      .button {
        height: 65px;
        border: none;
        border-radius: 15px;
        background: rgb(58, 52, 52);
        color: white;
        font-size: 22px;
        cursor: pointer;
      }
      button:hover {
        background: rgb(75, 60, 90);
      }
      .child1 {
        padding: 10px;
        border-radius: 5px;
        font-weight: bold;
        background: lightgreen;
      }
      .child2 {
